# pero_theia Bazel config

# ── Common ────────────────────────────────────────────────────────────────
build --enable_bzlmod
build --incompatible_enable_cc_toolchain_resolution

# ── Host (Linux x86_64) ───────────────────────────────────────────────────
build:linux --cpu=k8
build:linux --compiler=gcc

# ── ARM Cortex-R4F cross-compile (Hercules TMS570) ────────────────────────
build:cortex_r4f --platforms=//platforms:tms570lc43xx
build:cortex_r4f --crosstool_top=//toolchains/arm_gcc_7_2017q4:cc_suite
build:cortex_r4f --cpu=cortex-r4f
build:cortex_r4f --compiler=arm-none-eabi-gcc

# ── CI mode (no interactive output) ───────────────────────────────────────
build:ci --show_progress_rate_limit=30
build:ci --curses=no
test:ci  --test_output=errors

# ── Output shortcuts ──────────────────────────────────────────────────────
# bazel build //... --config=linux   → build all host targets
# bazel build //... --config=cortex_r4f → cross-compile firmware
