# pero_theia Bazel config

# ── Common ────────────────────────────────────────────────────────────────
build --enable_bzlmod
build --incompatible_enable_cc_toolchain_resolution

# ── Host (Linux x86_64) ───────────────────────────────────────────────────
build:linux --cpu=k8
build:linux --compiler=gcc

# ── ARM Cortex-R4F cross-compile (Hercules TMS570) ────────────────────────
build:cortex_r4f --platforms=//platforms:tms570lc43xx

# ── TI ARM CGT 18.1.1.LTS (original CCS 8 compiler) ─────────────────────
# Requires /opt/ti/cgt_arm_18.1.1.LTS/ installed.
build:ti_arm_cgt_18 --platforms=//platforms:tms570lc43xx_ti
build:ti_arm_cgt_18 --extra_toolchains=//toolchains/ti_arm_cgt_18:cc_suite

build:cortex_r4f --platforms=//platforms:tms570lc43xx_gcc
build:cortex_r4f --extra_toolchains=//toolchains/arm_gcc_7_2017q4:cc_suite
build:ti_arm_cgt_18 --strategy=CppCompile=local
build:ti_arm_cgt_18 --strategy=CppLink=local
build:ti_arm_cgt_18 --strategy=CppArchive=local
# Disable strict header inclusion checking — TI CGT headers are outside workspace
build:ti_arm_cgt_18 --features=-layering_check
build:ti_arm_cgt_18 --nocheck_visibility

# ── TI ARM CGT 18.1.1.LTS (original CCS 8 compiler) ─────────────────────
# Requires /opt/ti/cgt_arm_18.1.1.LTS/ installed locally.
# Produces .obj files and ELF using armcl + HL_sys_link.cmd linker script.
build:ti_arm_cgt_18 --platforms=//platforms:tms570lc43xx
build:ti_arm_cgt_18 --crosstool_top=//toolchains/ti_arm_cgt_18:cc_suite
build:ti_arm_cgt_18 --cpu=cortex-r4f
build:ti_arm_cgt_18 --compiler=armcl
build:ti_arm_cgt_18 --sandbox_strategy=off      # TI armcl needs host tools
build:ti_arm_cgt_18 --spawn_strategy=local

# ── CI mode (no interactive output) ───────────────────────────────────────
build:ci --show_progress_rate_limit=30
build:ci --curses=no
test:ci  --test_output=errors

# ── Output shortcuts ──────────────────────────────────────────────────────
# bazel build //... --config=linux   → build all host targets
# bazel build //... --config=cortex_r4f → cross-compile firmware
