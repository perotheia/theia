# pero_theia Bazel config

# ── Common ────────────────────────────────────────────────────────────────
build --enable_bzlmod
build --incompatible_enable_cc_toolchain_resolution

# ── Host (Linux x86_64) ───────────────────────────────────────────────────
build:linux --cpu=k8
build:linux --compiler=gcc

# ── ARM Cortex-R4F cross-compile — arm-none-eabi-gcc 7-2017-q4 ───────────
build:cortex_r4f --platforms=//platforms:tms570lc43xx_gcc
build:cortex_r4f --extra_toolchains=//toolchains/arm_gcc_7_2017q4:cc_suite

# ── TI ARM CGT 18.1.1.LTS — original CCS 8 compiler (armcl) ─────────────
# Requires /opt/ti/cgt_arm_18.1.1.LTS/ installed.
build:ti_arm_cgt_18 --platforms=//platforms:tms570lc43xx_ti
build:ti_arm_cgt_18 --extra_toolchains=//toolchains/ti_arm_cgt_18:cc_suite
build:ti_arm_cgt_18 --strategy=CppCompile=local
build:ti_arm_cgt_18 --strategy=CppLink=local
build:ti_arm_cgt_18 --strategy=CppArchive=local
build:ti_arm_cgt_18 --features=-layering_check
build:ti_arm_cgt_18 --nocheck_visibility

# ── CI mode (no interactive output) ───────────────────────────────────────
build:ci --show_progress_rate_limit=30
build:ci --curses=no
test:ci  --test_output=errors

# ── Output shortcuts ──────────────────────────────────────────────────────
# Host:     bazel build //... --config=linux
# GCC FW:   bazel build //gateway/pero_cmp_ti:pero_cmp_ti.elf --config=cortex_r4f
# TI FW:    bazel build //gateway/pero_cmp_ti:pero_cmp_ti.elf --config=ti_arm_cgt_18
