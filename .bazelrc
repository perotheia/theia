# pero_theia Bazel config

# ── Common ────────────────────────────────────────────────────────────────
build --enable_bzlmod
build --incompatible_enable_cc_toolchain_resolution
# OPTIMIZED by default. Bazel's stock `fastbuild` is -O0 — unsafe for this stack:
# real-time nodes miss their deadlines at -O0 (observed in the field: a 20 Hz
# corridor feed vs ~4 Hz -O0 planning → decisions lagged reality by ~2 s and the
# brake landed after contact). This also makes `theia release`/`dist` ship
# optimized binaries in the debs (previously fastbuild). Keep frame pointers so
# libtombstone crash backtraces stay walkable at -O2. Debug builds are explicit:
# `bazel build -c dbg //...`.
build -c opt
build --copt=-fno-omit-frame-pointer
# Default aarch64 ABI = rpi4 (bookworm sysroot). Both rpi4 + jetson are
# cpu:aarch64, so //rules/config:{arm64_cross,target_jetson} disambiguate on this
# define. Setting it here makes "no explicit define" resolve to the rpi4
# sysroot path (preserving the original aarch64 behaviour); the Jetson native
# build overrides with `--define theia_target=jetson`. Harmless on x86 (the
# arm64_* config_settings also require cpu:aarch64, so x86 hits the default).
build --define=theia_target=rpi4
# Pass the host PATH into Bazel actions so they can find `artheia` from
# the workspace venv (`PATH="$PWD/.venv/bin:$PATH" bazel build ...`).
# Used by //rules/psp.bzl for PspGenerate.
build --action_env=PATH

# nanopb's pb.h: the generated *.pb.h #include <pb.h>, which the proto
# cc_libraries expect on the system include path (the @nanopb bazel module
# doesn't cleanly expose a cc_library here). libnanopb-dev installs it either
# flat (/usr/include/pb.h — older) or under /usr/include/nanopb/ (0.4.8+).
# Add the subdir to the include path so both layouts resolve; harmless when the
# dir is absent (-I to a missing dir is ignored). HOST-ONLY: a cross-build
# (rpi4) gets nanopb's pb.h from its own sysroot, not a host path.
build:linux --copt=-I/usr/include/nanopb

# ── Host (Linux x86_64) ───────────────────────────────────────────────────
build:linux --cpu=k8
build:linux --compiler=gcc

# ── Raspberry Pi 4 (aarch64, Debian bookworm) — cross-compile ────────────
# Needs gcc-aarch64-linux-gnu + the sysroot at third_party/sysroot/rpi4
# (setup_rpi4.sh). The sysroot is host data outside the sandbox, so the cross
# actions run un-sandboxed (local) and read it via an absolute --sysroot.
build:rpi4 --platforms=//rules/config:rpi4
build:rpi4 --strategy=CppCompile=local --strategy=CppLink=local

# ── TI ARM CGT 18.1.1.LTS — original CCS 8 compiler (armcl) ─────────────
# Requires /opt/ti/cgt_arm_18.1.1.LTS/ installed.
build:ti_arm_cgt_18 --platforms=//toolchains:tms570lc43xx_ti
build:ti_arm_cgt_18 --extra_toolchains=//toolchains/ti_arm_cgt_18:cc_suite
build:ti_arm_cgt_18 --strategy=CppCompile=local
build:ti_arm_cgt_18 --strategy=CppLink=local
build:ti_arm_cgt_18 --strategy=CppArchive=local
build:ti_arm_cgt_18 --features=-layering_check
build:ti_arm_cgt_18 --nocheck_visibility

# ── CI mode (no interactive output) ───────────────────────────────────────
build:ci --show_progress_rate_limit=30
build:ci --curses=no
test:ci  --test_output=errors

# ── Output shortcuts ──────────────────────────────────────────────────────
# Host:     bazel build //... --config=linux
# GCC FW:   bazel build //gateway/firmware/pero_cmp_ti:pero_cmp_ti.elf --config=cortex_r4f
# TI FW:    bazel build //gateway/firmware/pero_cmp_ti:pero_cmp_ti.elf --config=ti_arm_cgt_18

# Host-local overrides (NOT committed): a native-board build box (jetson/orin)
# drops `build --linkopt=-L/usr/local/lib --host_linkopt=-L/usr/local/lib` here
# so the from-source grpc/protobuf closure resolves inside `theia dist`'s own
# bazel invocations (the jason lesson: a user.bazelrc that ISN'T imported is
# silently ignored — this line makes it real).
try-import %workspace%/user.bazelrc
