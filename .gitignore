.repo/

# Bazel symlinks at the workspace root (bazel-bin, bazel-out, bazel-testlogs, bazel-theia).
# Anchored to / so `docs/skills/bazel-build/` and other deeper bazel-* paths are unaffected.
/bazel-*
/workspace/
*.pyc
__pycache__/
/.venv/
dist/
/up/
/HANDOFF.md

# Component-repo checkout paths from .repo/manifests/default.xml.
# pero_theia sits at workspace root; the projects below are sibling
# git repos checked out into this tree by `repo sync` and must not
# appear as untracked in pero_theia.
/artheia/
/autosar/demo/mlbevo_gen2_cmp_demo/
/gateway/demo/pero_cmp_gw_cln_demo/
/gateway/firmware/pero_cmp_ti/
/gateway/firmware/pero_cmp_ti_gw/
/gateway/libs/libgw/
/gateway/libs/pero_cmp_lnx/
/platform/gateway/
# vendor/autosar/mlbevo_gen2_cmp_psp/ — optional, see .repo/local_manifests/psp.xml

# Local agent/IDE state — never tracked.
/.claude/

# nanopb codegen outputs under platform/proto/system/services/<fc>/.
# Generated by the per-FC genrule from <fc>.proto on every bazel
# build (see platform/proto/system/services/sm/BUILD.bazel for the
# template). The .proto stays committed; the .pb.{c,h} don't.
/platform/proto/system/services/*/*.pb.c
/platform/proto/system/services/*/*.pb.h

# Vendor implementations are tracked separately (their own GitLab repos,
# wired in via .repo/local_manifests/ on demand). Do not commit generated
# vendor artifacts to pero_theia. Keep the namespace marker
# (vendor/__init__.py) tracked so `pip install -e .` resolves vendor.*
# even when the data dirs are absent.
/vendor/*/
!/vendor/.gitkeep
/vendor/packages/
/vendor/vehicles/
/vendor/apps/
/theia_vendor.egg-info/

# Derived from up/AUTOSAR_TPS_ManifestSpecification.pdf via
# `pdftotext -layout` + the chapter splitter. Regeneratable; don't bloat
# the repo with vendor spec text.
/docs/autosar/spec/

# Fake bash daemons emitted by the supervisor demo helper. The real
# daemons are bazel-built binaries; these are placeholders.
/services/*/daemon.sh

# CMake build trees — generic catch-all (covers applications/*/build/,
# /demo/build/, supervisor-gui/build/, etc.).
build/
# Per-target cross-compile build dirs (rpi4, etc.) — same idea, just
# with an arch suffix so the host build coexists with cross builds.
build-*/

# Generated by artheia importers (import-dbc / import-fibex) from the
# vendor PSP files in up/. Treat as build output; the .art is the human
# source, catalog.json / netgraph.json are regeneratable LUTs.
/platform/system/autosar/generated/

# Generated by `artheia gen-proto` from the supervisor's .art. The .art
# source lives in platform/supervisor/system/; regenerate with:
#   artheia gen-proto platform/supervisor/system/package.art \
#       --out platform/supervisor/generated/proto
/platform/supervisor/generated/

# Docker deploy runtime outputs.
deploy/.staging/
deploy/logs/

# supdbg's grpc_tools.protoc output. Regenerate with:
#   tools/supdbg/gen_protos.sh
/tools/supdbg/_gen/

# aarch64 sysroots for cross-compilation. The bootstrapped rootfs is
# ~450 MB of .debs; gitignore the contents but keep the setup scripts.
#   third_party/sysroot/setup_rpi4.sh   (see docs/tasks/BACKLOG/cross-compile-rpi4.md)
/third_party/sysroot/*
!/third_party/sysroot/setup_*.sh
!/third_party/sysroot/README.md

# Vendored third-party source pulled by `repo sync` from the manifest's
# `github` remote — the source itself is tracked in its own git repo,
# not in pero_theia. We only ship build artifacts (install/) and our
# own integration glue.
/third_party/etcd-cpp-apiv3/
core.*
.gdb_history
