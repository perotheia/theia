.repo/
.claude/
# Bazel symlinks at the workspace root (bazel-bin, bazel-out, bazel-testlogs, bazel-theia).
# Anchored to / so `docs/skills/bazel-build/` and other deeper bazel-* paths are unaffected.
/bazel-*
/workspace/
*.pyc
__pycache__/
/.venv/
dist/
/up/
/HANDOFF.md

# Component-repo checkout paths from .repo/manifests/default.xml.
# pero_theia sits at workspace root; the projects below are sibling
# git repos checked out into this tree by `repo sync` and must not
# appear as untracked in pero_theia.
/artheia/
/autosar/mlbevo_gen2_cmp_psp/
/autosar/demo/mlbevo_gen2_cmp_demo/
/gateway/firmware/pero_cmp_ti/
/gateway/firmware/pero_cmp_ti_gw/
/gateway/libs/libgw/
/gateway/libs/pero_cmp_lnx/
/gateway/demo/pero_cmp_gw_cln_demo/
/services/pero_cmp_gw_svc/

# Vendor implementations are tracked separately (their own GitLab repos,
# wired in via .repo/local_manifests/ on demand). Do not commit generated
# vendor artifacts to pero_theia.
/vendor/*/
!/vendor/.gitkeep

# Generated app build trees
applications/*/build/

# Demo project's CMake build dir
/demo/build/
