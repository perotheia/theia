<?xml version="1.0" encoding="UTF-8"?>
<!--
  pero_theia — repo manifest for PERO CMP workspace
  Usage:
    repo init -u git@cicd.skyway.porsche.com:PG50/pero_theia.git -b main
    repo sync -j8
    repo forall -c 'git checkout bz-migration'
-->
<manifest>

  <remote name="skyway"
          fetch="git@cicd.skyway.porsche.com:PG50/ccstheia"
          review="cicd.skyway.porsche.com" />

  <!-- manifest repo itself -->
  <remote name="theia"
          fetch="git@cicd.skyway.porsche.com:PG50" />

  <default remote="skyway"
           revision="bz-migration"
           sync-j="4" />

  <!-- ── Hercules firmware ───────────────────────────────────────────── -->
  <project name="pero_cmp_ti"
           path="pero_cmp_ti"
           revision="bz-migration" />

  <project name="pero_cmp_ti_gw"
           path="pero_cmp_ti_gw"
           revision="bz-migration" />

  <!-- ── Linux host ─────────────────────────────────────────────────── -->
  <project name="pero_cmp_lnx"
           path="pero_cmp_lnx"
           revision="bz-migration" />

  <!-- ── Gateway service + client ───────────────────────────────────── -->
  <project name="pero_cmp_gw_svc"
           path="pero_cmp_gw_svc"
           revision="bz-migration" />

  <project name="pero_cmp_gw_cln_demo"
           path="pero_cmp_gw_cln_demo"
           revision="bz-migration" />

  <!-- ── Platform support package + demo app ────────────────────────── -->
  <project name="mlbevo_gen2_cmp_psp"
           path="mlbevo_gen2_cmp_psp"
           revision="bz-migration" />

  <project name="mlbevo_gen2_cmp_demo"
           path="mlbevo_gen2_cmp_demo"
           revision="bz-migration" />

  <!-- ── This manifest repo (pinned separately) ─────────────────────── -->
  <project name="pero_theia"
           path="pero_theia"
           remote="theia"
           revision="main" />

</manifest>
