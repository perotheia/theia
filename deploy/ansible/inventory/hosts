# Theia rig inventory — agentless SSH targets, grouped by rig + machine role.
#
# A "rig" is one vehicle/test-bench (a TIPC cluster, isolated by tipc_cluster_id —
# see deploy/run-supervisor.sh). Each rig has machines by role: `central` (the
# etcd host + gateway) and `compute` (the AUTOSAR worker). The group vars map a
# host to its artheia manifest machine name (machine=) so the playbooks push the
# right dist/manifest/<machine>/ slice.
#
# Real fleets generate this from the manifest; this is the dev/lab template.
# `theia provision <machine>` / `theia orchestrate <machine>` target one host.

[all:vars]
# The artheia manifest tree ON THE CONTROLLER (theia dist output). Pushed per-host.
# Resolved against the repo root (deploy/ansible/../../dist/manifest) so the
# controller-side file lookups work regardless of where ansible-playbook is run.
# Override with -e manifest_dir=/abs/path for a different dist tree.
manifest_dir      = {{ playbook_dir }}/../../dist/manifest
etcd_machine      = central

# ----- lab rig (the dev bench: dalek controller, rpi4 + x86 boxes) -----------
[rig_lab:children]
rig_lab_central
rig_lab_compute

[rig_lab_central]
# rig1-central is the ssh-config alias (user=axadmin, host=10.0.0.22); the rpi4.
rig1-central    ansible_host=10.0.0.22  ansible_user=axadmin  machine=central

[rig_lab_compute]
# add compute nodes here, e.g.:
# taycann ansible_host=10.0.0.33  machine=compute

[rig_lab:vars]
rig_id = lab

# ----- odd-path GPS-feed rig (manifest.odd_path.rig) -------------------------
# The Pi that runs the reduced services slice feeding odd-path-monitor's GPS.
# machine=gpsfeed (NOT central): its own deploy/config/gpsfeed/ profile disables
# the PTP daemons (no ptpIf0 on this box). Same physical Pi as rig1-central for
# now; deploy with `theia orchestrate gpsfeed -l rig1-gpsfeed`.
[rig_gpsfeed]
rig1-gpsfeed    ansible_host=10.0.0.22  ansible_user=axadmin  machine=gpsfeed
