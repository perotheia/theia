# theia-supervisor.service — boot-time autostart for a baremetal rig (an outdoor
# headless Pi reached only over VPN). Rendered + installed by
# tasks/install-supervisor-unit.yml. ExecStart calls run-supervisor.sh (shipped
# alongside) so all the TIPC-clusterid / logger-policy / TLS / instance env logic
# lives in ONE place — the unit just owns the lifecycle (restart, boot order).
#
# The supervisor sets PR_SET_PDEATHSIG on its children, so a unit stop/restart
# cleanly tears the whole FC tree down (no orphan sweep needed on c7f5b3b+).
[Unit]
Description=Theia supervisor ({{ machine }}) — the ARA Execution Manager
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
Environment=THEIA_ROOT=/opt/theia
Environment=THEIA_MACHINE={{ machine }}
# run-supervisor.sh reads <machine>/execution.json for the TIPC instance + logger
# policy, sets LD_LIBRARY_PATH=/opt/theia/lib, then exec's /opt/theia/bin/supervisor.
ExecStart=/opt/theia/run-supervisor.sh {{ machine }}
# Bounded restart: a crash re-execs, but a crash-loop backs off rather than
# hammering (matches run-supervisor.sh's own bounded re-exec intent).
Restart=on-failure
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5
# The supervisor needs the caps setcap already applied to the binary; systemd
# does not strip file caps for Type=simple, so AmbientCapabilities is not needed.

[Install]
WantedBy=multi-user.target
