# Front reverse proxy for the Headscale admin UI — serves the SPA and the
# Headscale REST API under ONE origin (http://10.0.0.99:8081) so the browser
# SPA's /api/v1 calls are same-origin (Headscale emits no CORS headers, so a
# cross-origin :8081→:8080 call would be blocked).
#
#   /admin/*  → headscale-admin (the static SPA)
#   /api/*    → headscale (the REST mgmt API the SPA + tools/rig-enroll use)
#   /*        → headscale (Tailscale control endpoints, so :8081 is a full front)
#
# In the admin UI (http://10.0.0.99:8081/admin/), set the Headscale URL to the
# SAME ORIGIN — "http://10.0.0.99:8081" — and paste an API key
# (headscale apikeys create --expiration 90d). The key is stored browser-side.

:8081 {
	# The admin SPA already lives under /admin/ in its container — DON'T strip the
	# prefix (handle, not handle_path), just proxy it through.
	handle /admin/* {
		reverse_proxy headscale-admin:80
	}

	handle /api/* {
		reverse_proxy headscale:8080
	}

	# Everything else → the Headscale control server (so a single front works).
	handle /* {
		reverse_proxy headscale:8080
	}
}
