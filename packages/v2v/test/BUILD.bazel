# packages.v2v unit tests — the algorithm parity gates (link the v2v_algo lib).
load("@rules_cc//cc:defs.bzl", "cc_test")

package(default_visibility = ["//visibility:public"])

_EIGEN_COPTS = select({
    "@pero_theia//rules/config:is_arm64": ["-I=/usr/include/eigen3"],
    "//conditions:default": ["-I/usr/include/eigen3"],
})

# Relative-topology SLAM estimator parity (HANDOFF_CPP_V2V.md §7).
cc_test(
    name = "test_estimator",
    srcs = ["test_estimator.cc"],
    copts = ["-std=c++17", "-fPIC"] + _EIGEN_COPTS,
    deps = ["//packages/v2v/impl:v2v_algo"],
)

# Cooperative-alert consensus parity (HANDOFF2 §7): convergence, E3 majority,
# E5 lone-witness containment.
cc_test(
    name = "test_consensus",
    srcs = ["test_consensus.cc"],
    copts = ["-std=c++17", "-fPIC"] + _EIGEN_COPTS,
    deps = ["//packages/v2v/impl:v2v_algo"],
)
