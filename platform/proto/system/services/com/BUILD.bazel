# Generated nanopb sources for the system.services.com package.
# Layout mirrors platform/proto/gateway/system/ — filegroups consumed
# by platform/proto/BUILD.bazel's :platform_protos cc_library.

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "com_pb_c",
    srcs = ["com.pb.c"],
)

filegroup(
    name = "com_pb_h",
    srcs = ["com.pb.h"],
)

filegroup(
    name = "com_proto",
    srcs = ["com.proto"],
)
