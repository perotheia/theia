# Generated nanopb sources for the system.services.sm package.
#
# .pb.{c,h} are now BUILT, not committed: the genrule below invokes
# nanopb_generator (a system-installed tool) on the .proto. To
# regenerate manually for inspection, run from the repo root:
#
#   nanopb_generator platform/proto/system/services/sm/sm.proto
#
# Earlier revisions committed the .pb.{c,h} alongside the .proto;
# they're regenerable, so the genrule is the source of truth now.

package(default_visibility = ["//visibility:public"])

genrule(
    name = "sm_pb",
    srcs = ["sm.proto"],
    outs = [
        "sm.pb.c",
        "sm.pb.h",
    ],
    cmd = "set -e;"
        + " in_dir=$$(dirname $(location sm.proto));"
        + " out_dir=$$(dirname $(location sm.pb.c));"
        + " nanopb_generator -I $$in_dir -D $$out_dir sm.proto;",
    tools = [],
    # nanopb_generator is host-installed; if not on PATH, builds fail
    # with a clear error. Future: hermetic via @nanopb//:nanopb_generator
    # once the Bazel module exposes a usable tool target.
    local = True,
)

filegroup(
    name = "sm_pb_c",
    srcs = ["sm.pb.c"],
)

filegroup(
    name = "sm_pb_h",
    srcs = ["sm.pb.h"],
)

filegroup(
    name = "sm_proto",
    srcs = ["sm.proto"],
)


# ---------------------------------------------------------------------------
# Google libprotobuf companion ‚Äî REFLECTION-capable C++ binding of the
# same .proto. Host-only (libtrace_decoder, supdbg). Apps + services on
# Hercules/RPi4 keep using the nanopb `sm_pb_c`/`sm_pb_h` targets above.
#
# protoc writes `sm.pb.cc` / `sm.pb.h` ‚Äî `sm.pb.h` would collide with
# nanopb's, so we emit into a `cpp/` subdir. Consumers include
# "system/services/sm/cpp/sm.pb.h".
# ---------------------------------------------------------------------------

load("@rules_cc//cc:defs.bzl", "cc_library")

genrule(
    name = "sm_pb_cpp_gen",
    srcs = ["sm.proto"],
    outs = [
        "cpp/sm.pb.cc",
        "cpp/sm.pb.h",
    ],
    cmd = "set -e;"
        + " in_dir=$$(dirname $(location sm.proto));"
        + " out_dir=$$(dirname $$(dirname $(location cpp/sm.pb.cc)));"
        + " mkdir -p $$out_dir/cpp;"
        + " protoc -I $$in_dir --cpp_out=$$out_dir/cpp sm.proto;",
    local = True,
)

cc_library(
    name = "sm_pb_cpp",
    srcs = ["cpp/sm.pb.cc"],
    hdrs = ["cpp/sm.pb.h"],
    # `cpp/` is the include root so callers write
    # `#include "sm.pb.h"` after taking this dep ‚Äî matches the file
    # protoc actually wrote at $out_dir/cpp/.
    includes = ["cpp"],
    deps = ["//third_party:system_protobuf"],
    visibility = ["//visibility:public"],
)
