load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

"""platform/runtime — host-runtime abstraction for applications + services.

Provides the gen_server-shaped actor stack (GenServer, NodeRef,
TimerService, TipcMux, Tracer) plus the legacy Adaptive-AUTOSAR-ish
facade (Logger, Clock, Timer, LifecycleInterface, RuntimeContext) that
the existing OddPathMonitor stack still consumes. Lives at the
workspace top level because it sits above both applications/ and
services/.

Wire / serialization helpers (RemoteCodec, encode_for_trace) include
libgw's gw_proto.h, so this library carries a transitive dep on
//gateway/libs/libgw:gw.

Don't put gateway-comms-specific code here (CMP wire framing, FIBEX,
PSP loading). That stays in gateway/libs/{pero_cmp_lnx, libgw}.
"""

package(default_visibility = ["//visibility:public"])

# Control-plane nanopb codec (#386), generated from
# system/package.art (package platform.runtime). Compiled INTO the
# runtime library so both the supervisor (sender) and every FC app
# (receiver, via GenServer's register_cast) link the SAME
# platform_runtime_LogLevelPush type. .pb.{c,h} are BUILT, not
# committed — regenerate the .proto with:
#   artheia gen-proto-package platform/runtime/system/package.art \
#       --out platform/runtime/proto
genrule(
    name = "control_pb",
    srcs = ["proto/platform_runtime/runtime.proto"],
    outs = [
        "proto/platform_runtime/runtime.pb.c",
        "proto/platform_runtime/runtime.pb.h",
    ],
    cmd = "set -e;"
        + " in_dir=$$(dirname $(location proto/platform_runtime/runtime.proto));"
        + " out_dir=$$(dirname $(location proto/platform_runtime/runtime.pb.c));"
        + " nanopb_generator -I $$in_dir -D $$out_dir runtime.proto;",
    tools = [],
    local = True,  # host-installed nanopb_generator, same as the FC protos
)

cc_library(
    name = "runtime",
    srcs = glob(["src/*.cc"]) + ["proto/platform_runtime/runtime.pb.c"],
    hdrs = glob(["include/*.hh"]) + ["proto/platform_runtime/runtime.pb.h"],
    includes = [
        "include",
        "proto",   # so callers #include "platform_runtime/runtime.pb.h"
    ],
    copts = [
        "-Wall",
        "-Wextra",
        "-std=c++17",   # gen_server stack uses inline-vars + if-constexpr
        "-fPIC",
    ],
    deps = ["//gateway/libs/libgw:gw"],
    linkopts = [
        "-lpthread",
        "-l:libprotobuf-nanopb.a",
    ],
)

# ---- Test suite (gen_server runtime; mirrors slices of OTP's
#      gen_server_SUITE.erl). Self-contained nanopb proto under
#      test/proto/ so the cc_test has no external app dependencies.

cc_library(
    name = "test_protos",
    srcs = ["test/proto/platform_runtime_test/messages.pb.c"],
    hdrs = ["test/proto/platform_runtime_test/messages.pb.h"],
    includes = ["test/proto"],
    copts = ["-fPIC"],
)

cc_test(
    name = "tests",
    srcs = [
        "test/test_main.cc",
        "test/test_server.hh",
        "test/test_codecs.hh",
        "test/test_statem.hh",
    ],
    includes = ["test"],
    copts = ["-std=c++17", "-Wall", "-Wextra"],
    deps = [
        ":runtime",
        ":test_protos",
    ],
    # The 3-process cases (tipc_3process, tipc_3process_generated) skip
    # cleanly when the demo's per-process binaries aren't on PATH —
    # this Bazel test is self-contained.
)
