#!/bin/sh
# theia-swp — a Mender Update Module that installs a user SOFTWARE PACKAGE (SWP) as
# a whole RELEASE and atomically FLIPS current → it (the day-2/3 app plane).
#
# Two-plane OTA (docs/design/two-plane-ota.md). Exactly ONE active release at a
# time; a rollout is an atomic current-flip; rollback is the reverse. The runtime
# and the SWP are independent planes that meet only on this file layout:
#
#   theia-release  the RUNTIME as a release: releases/runtime-<ver>/{bin,config}.
#                  Colony/deb lays it + current → it (the resting state).
#   theia-swp      an SWP as a release: releases/<swp>-<ver>/{bin,config}, built by
#                  copying the CURRENT release's services bin + overlaying the SWP's
#                  FC bin, and using the SWP's OWN executor.json (services + FCs) as
#                  the release config. Then flip current → it. The supervisor reads
#                  current/config/executor.json (via theia-run). bin/supervisor
#                  stays flat — the release carries only the CHILDREN.
#
# Why a full release (not a merge): the SWP already ships a complete
# manifest/<machine>/executor.json (services baseline + its FC nodes), so we make
# it a real release dir and flip — no in-place mutation of a shared config, no
# accumulation of two SWPs' procs, rollback is one symlink flip. (The prior model
# merged the SWP's app group into a shared /opt/theia/config/executor.json, which
# left multiple SWPs' procs co-resident — see the design doc's problem statement.)
#
# Artifact payload (produced by `theia release-swp`):
#   <app>-<ver>.tar.gz   tar of { bin/<fc>, manifest/machines.json,
#                                 manifest/<machine>/{machine,executor,application}.json,
#                                 version.txt, requires_runtime.txt, [migration/] }
#   version.txt          <app>-<ver>-<abi>  (the artifact-name gate + release dir name)
#
# Mender invokes:  theia-swp <STATE> <payload-files-dir>
set -eu

STATE="$1"
FILES="${2:-}"

THEIA_ROOT="${THEIA_ROOT:-/opt/theia}"
RELEASES="$THEIA_ROOT/releases"
CURRENT="$THEIA_ROOT/current"
PREVIOUS="$THEIA_ROOT/previous"
MACHINE="${THEIA_MACHINE:-master}"       # the role whose executor slice to activate

_payload() {   # echo the path to a payload file, files/ or bare
    if [ -f "$FILES/files/$1" ]; then echo "$FILES/files/$1";
    elif [ -f "$FILES/$1" ]; then echo "$FILES/$1"; fi
}

_artifact_name() {
    vt="$(_payload version.txt)"
    [ -n "$vt" ] && cat "$vt" || echo "unknown"
}

# The <machine> subdir inside the SWP tar whose executor.json we activate. Prefer
# $THEIA_MACHINE (the board's role) if the SWP ships a slice for it — a
# multi-machine SWP applies the CORRECT slice per board; fall back to the sole one.
_swp_machine_dir() {   # $1 = untarred SWP staging dir; echoes manifest/<machine>
    stg="$1"
    if [ -d "$stg/manifest/$MACHINE" ]; then echo "manifest/$MACHINE"; return; fi
    d="$(ls -d "$stg"/manifest/*/ 2>/dev/null | head -1 || true)"
    [ -n "$d" ] && echo "manifest/$(basename "$d")"
}

# ---- runtime-dependency gate (preserved from the merge model) ----------------
# The installed theia-runtime deb version (M.m.p), or "" if not provisioned.
_installed_runtime() {
    dpkg-query -W -f='${Version}' theia-runtime 2>/dev/null || true
}
# Does the installed runtime satisfy the SWP's requires_runtime? major.minor must
# match; patch is tolerated. Empty pin = unpinned → always satisfied.
_runtime_satisfies() {
    pin="$1"; got="$2"
    [ -n "$pin" ] || return 0
    [ -n "$got" ] || return 1
    pin_mm="$(echo "$pin" | sed 's/-[a-z0-9._-]*$//' | cut -d. -f1,2)"
    got_mm="$(echo "$got" | sed 's/^[0-9]*://; s/-.*$//' | cut -d. -f1,2)"
    [ "$pin_mm" = "$got_mm" ]
}
# Gate the SWP install on the runtime (GS fans runtime→colony + app→Mender in
# parallel, so the SWP can arrive before its runtime deb). WAIT until satisfied.
_require_runtime() {
    pin="$1"
    got="$(_installed_runtime)"
    if _runtime_satisfies "$pin" "$got"; then
        echo "theia-swp: runtime dependency satisfied (requires '$pin', installed '$got')"
        return 0
    fi
    T="${THEIA_SWP_RUNTIME_WAIT_S:-3600}"
    echo "theia-swp: runtime not ready (requires '$pin', installed '${got:-none}') — SWP PENDING, re-checking every 10s (up to ${T}s; cancel in the GS to abort)"
    waited=0
    while [ "$waited" -lt "$T" ]; do
        sleep 10; waited=$((waited + 10))
        got="$(_installed_runtime)"
        if _runtime_satisfies "$pin" "$got"; then
            echo "theia-swp: runtime now satisfied (installed '$got') after ${waited}s — proceeding"
            return 0
        fi
    done
    echo "theia-swp: runtime dependency '$pin' not satisfied within ${T}s (installed '${got:-none}') — failing install" >&2
    return 1
}

# ---- major migration hook (preserved) ----------------------------------------
# A MAJOR SWP ships migration/{migration.json, plugins} and runs theia-migrate
# forward BEFORE the flip (against the still-current release, so per holds the
# pre-upgrade config). A non-zero exit aborts the install (Mender rolls back). No
# migration/ dir → free-swap no-op.
_run_migration() {
    work="$1"
    [ -f "$work/migration/migration.json" ] || {
        echo "theia-swp: no config migration (free-swap SWP)"; return 0; }
    tm="$THEIA_ROOT/bin/theia-migrate"
    [ -x "$tm" ] || { echo "theia-swp: $tm missing (runtime too old for config migration)" >&2; return 1; }
    echo "theia-swp: running config migration (theia-migrate forward)"
    if "$tm" forward "$work/migration"; then
        echo "theia-swp: config migration OK"; return 0
    else
        echo "theia-swp: config migration FAILED — aborting install" >&2; return 1
    fi
}

# ---- supervisor restart (preserved; adopts the flipped current/config) -------
# The supervisor reads executor.json once at startup (static tree, no hot-reload),
# so "adopt the flip" = RESTART it: it re-reads current/config/executor.json (now
# the SWP's) and spawns the SWP's tree. systemd path preferred; container fallback.
_reload_supervisor() {
    if [ -x "$THEIA_ROOT/bin/tdb" ] && "$THEIA_ROOT/bin/tdb" reload 2>/dev/null; then
        echo "theia-swp: supervisor reloaded (tdb)"; return 0
    fi
    if command -v systemctl >/dev/null 2>&1 && systemctl cat theia-supervisor >/dev/null 2>&1; then
        systemctl restart theia-supervisor 2>/dev/null \
            && { echo "theia-swp: supervisor restarted (systemd) — adopting current/config"; return 0; }
    fi
    launcher="$THEIA_ROOT/bin/theia-run"
    me=$$
    for pid in $(pgrep -x supervisor 2>/dev/null); do
        [ "$pid" = "$me" ] && continue
        kill -TERM "$pid" 2>/dev/null || true
    done
    i=0; while [ $i -lt 16 ] && pgrep -x supervisor >/dev/null 2>&1; do sleep 0.5; i=$((i+1)); done
    if [ -x "$launcher" ]; then
        ( THEIA_ROOT_DIR="$THEIA_ROOT" setsid "$launcher" >/var/log/theia-supervisor.log 2>&1 < /dev/null & )
        sleep 3
        pgrep -x supervisor >/dev/null 2>&1 \
            && echo "theia-swp: supervisor relaunched via theia-run — adopting current/config" \
            || echo "theia-swp: supervisor relaunch did not come up — check /var/log/theia-supervisor.log" >&2
    else
        echo "theia-swp: no launcher to relaunch (runtime not provisioned?) — adopts on next start" >&2
    fi
}

# ---- the flip: stage the SWP as a real release + atomically re-aim current ----
_stage_and_flip() {
    ver="$1"; work="$2"
    # The base release providing the services bin: whatever current resolves to
    # (runtime-<ver> at rest, or a prior SWP — either carries services bin).
    base_rel_dir="$(cd "$THEIA_ROOT" && readlink -f "$CURRENT")"
    [ -d "$base_rel_dir/bin" ] || {
        echo "theia-swp: current ($CURRENT) has no bin/ — runtime not staged?" >&2; return 1; }
    mdir="$(_swp_machine_dir "$work")"
    [ -n "$mdir" ] && [ -f "$work/$mdir/executor.json" ] || {
        echo "theia-swp: SWP has no manifest/<machine>/executor.json (machine=$MACHINE)" >&2; return 1; }

    # Snapshot the rollback target FIRST (the release running before this attempt).
    if [ -L "$CURRENT" ]; then
        ln -sfn "$(readlink "$CURRENT")" "$PREVIOUS"
    fi

    # Assemble releases/<ver>/{bin,lib,config}: services bin + SWP FC bin; the base
    # release's lib (theia-run sets LD_LIBRARY_PATH=current/lib, so the dir must
    # exist even when empty — services link system .so's + bundled libs from here);
    # SWP config.
    stage="$RELEASES/$ver"
    rm -rf "$stage"; mkdir -p "$stage/bin" "$stage/lib" "$stage/config"
    cp -a "$base_rel_dir/bin/." "$stage/bin/" 2>/dev/null || true       # services baseline
    [ -d "$base_rel_dir/lib" ] && cp -a "$base_rel_dir/lib/." "$stage/lib/" 2>/dev/null || true  # bundled libs
    [ -d "$work/bin" ] && cp -a "$work/bin/." "$stage/bin/" 2>/dev/null || true   # SWP FCs win
    [ -d "$work/lib" ] && cp -a "$work/lib/." "$stage/lib/" 2>/dev/null || true   # SWP libs (if any)
    cp -a "$work/$mdir/executor.json" "$stage/config/executor.json"     # the SHADOWING config
    for f in "$work/$mdir/"*.json; do                                   # per-FC config profiles
        [ -f "$f" ] || continue
        b="$(basename "$f")"; [ "$b" = executor.json ] && continue
        cp -a "$f" "$stage/config/$b"
    done
    [ -f "$work/manifest/machines.json" ] && cp -a "$work/manifest/machines.json" "$stage/config/machines.json"
    echo "$ver" > "$stage/.mender_version"
    echo "theia-swp: staged SWP release $ver → $stage (services from $(basename "$base_rel_dir"))"

    # Atomic re-aim: temp symlink + rename(2) over current.
    tmp="$THEIA_ROOT/.current.$$"
    ln -sfn "releases/$ver" "$tmp"
    mv -T "$tmp" "$CURRENT"
    echo "theia-swp: current → releases/$ver (previous → $(readlink "$PREVIOUS" 2>/dev/null || echo none))"
}

# Allow sourcing for the helper functions (tests) without dispatching: a caller
# that sets THEIA_SWP_SOURCE_ONLY gets the functions defined but no state action.
[ -n "${THEIA_SWP_SOURCE_ONLY:-}" ] && return 0 2>/dev/null || true

case "$STATE" in
  Download)
    : ;;   # Mender auto-saves the payload to files/

  ArtifactInstall)
    art="$(_artifact_name)"
    [ "$art" != "unknown" ] || { echo "theia-swp: no version.txt" >&2; exit 1; }

    tarball="$(ls "$FILES"/files/*.tar.* 2>/dev/null | head -1 || true)"
    [ -n "$tarball" ] || tarball="$(ls "$FILES"/*.tar.* 2>/dev/null | head -1 || true)"
    [ -n "$tarball" ] || { echo "theia-swp: no SWP tarball in payload" >&2; exit 1; }
    work="$(mktemp -d)"
    case "$tarball" in
      *.zst) zstd -dc "$tarball" | tar -x -C "$work" ;;
      *.gz)  tar -xzf "$tarball" -C "$work" ;;
      *)     tar -xf "$tarball"  -C "$work" ;;
    esac

    # runtime precondition (deploy sequencing).
    req_rt="$(_payload requires_runtime.txt)"
    pin=""; [ -n "$req_rt" ] && pin="$(tr -d '[:space:]' < "$req_rt")"
    _require_runtime "$pin" || { rm -rf "$work"; exit 1; }

    # MAJOR migration (against the still-current release), then stage + flip.
    _run_migration "$work" || { rm -rf "$work"; exit 1; }
    _stage_and_flip "$art" "$work" || { rm -rf "$work"; exit 1; }
    rm -rf "$work"
    echo "theia-swp: installed SWP release '$art'"
    ;;

  ArtifactCommit)
    # The flip happened in ArtifactInstall; restart the supervisor so it adopts
    # current/config (the SWP's executor). Standalone this is the activation.
    _reload_supervisor
    echo "theia-swp: committed current=$(readlink "$CURRENT" 2>/dev/null)"
    ;;

  ArtifactRollback)
    if [ -L "$PREVIOUS" ]; then
        prev="$(readlink "$PREVIOUS")"
        tmp="$THEIA_ROOT/.current.$$"
        ln -sfn "$prev" "$tmp"
        mv -T "$tmp" "$CURRENT"
        echo "theia-swp: ROLLBACK current → $prev"
        _reload_supervisor
    else
        echo "theia-swp: no previous to roll back to" >&2
    fi
    ;;

  SupportsRollback)   echo "Yes" ;;
  NeedsArtifactReboot) echo "No" ;;

  Cleanup)
    rm -f "$THEIA_ROOT"/.current.* 2>/dev/null || true
    ;;

  *) exit 0 ;;
esac
