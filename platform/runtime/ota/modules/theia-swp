#!/bin/sh
# theia-swp — a Mender Update Module that installs a user SOFTWARE PACKAGE (SWP) as
# an OVERLAY on the running release (the day-2 package plane). The runtime/SWP
# dichotomy on-device:
#
#   theia-release  swaps the WHOLE release (current → releases/<ver>) — the
#                  platform (supervisor + services), colony's factory job.
#   theia-swp      overlays ONLY the SWP's FC executables into the live release +
#                  merges the SWP's executor subtree into the supervised tree +
#                  reloads the supervisor. Services + supervisor are NEVER touched.
#
# Artifact payload (produced by `theia release-swp`) — manifest-driven, NO app.json:
#   <app>-<ver>.tar.gz   tar of { bin/<fc> (all compositions),
#                                 manifest/machines.json,
#                                 manifest/<machine>/{machine,executor,application}.json,
#                                 version.txt }
#   version.txt          <app>-<ver>-<abi>  (the artifact-name gate)
#   machines.json        {app, roles, arity, on, machines}  (the SWP identity)
#
# Install model (overlay, reversible):
#   - copy bin/<fc> → $CURRENT/bin/<fc>   (the SWP FCs join the running release)
#   - merge the SWP's executor subtree (manifest/<machine>/executor.json worker
#     nodes) → $THEIA_ROOT/config/executor.json under the root, keyed by the SWP
#     name so a re-install replaces the SAME SWP's nodes (idempotent).
#   - back up the prior {bin copies, executor} so ArtifactRollback restores them.
#   - reload the supervisor (tdb reload if present) so it (re)spawns the SWP FCs.
#
# Mender invokes:  theia-swp <STATE> <payload-files-dir>
set -eu

STATE="$1"
FILES="${2:-}"

THEIA_ROOT="${THEIA_ROOT:-/opt/theia}"
CURRENT="$THEIA_ROOT/current"
EXEC="$THEIA_ROOT/config/executor.json"
SWP_STATE="$THEIA_ROOT/swp"              # per-SWP install records (for rollback)

_payload() {   # echo the path to a payload file, files/ or bare
    if [ -f "$FILES/files/$1" ]; then echo "$FILES/files/$1";
    elif [ -f "$FILES/$1" ]; then echo "$FILES/$1"; fi
}

_artifact_name() {
    vt="$(_payload version.txt)"
    [ -n "$vt" ] && cat "$vt" || echo "unknown"
}

# Merge the SWP's executor subtree into the running executor.json under the root,
# REPLACING any nodes previously installed for the same SWP (idempotent).
# Source = manifest/<machine>/executor.json (the per-machine supervised tree).
#
# The SWP's contribution is the `applications_sup` supervisor GROUP (the app
# processes), a sibling of the runtime's `services_sup`. We graft THAT group as a
# single child of the live root — preserving its one_for_one supervisor semantics
# — NOT a flat name-match of every shipped proc (the SWP tar ships ALL bins of
# every composition, so a name-match would duplicate the runtime services). If the
# source has no applications_sup (legacy/hand-written), fall back to grafting only
# the app worker leaves whose names are NOT already supervised by the live tree.
# Python is on every Theia rig (the framework wheel).
_merge_executor() {
    swp_name="$1"; src_exec="$2"; procs="$3"
    python3 - "$EXEC" "$src_exec" "$swp_name" "$procs" <<'PY'
import json, sys, os
exec_path, src_path, name, procs = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4].split()
src = json.load(open(src_path))
tree = json.load(open(exec_path)) if os.path.exists(exec_path) else {"name": "root", "children": []}
key = "children" if "children" in tree else ("workers" if "workers" in tree else "nodes")
kids = tree.setdefault(key, [])

# names already supervised by the LIVE tree (so a fallback graft never re-adds the
# runtime services that the SWP tar also carries).
live = set()
def collect_live(n):
    if isinstance(n, dict):
        if n.get("start_cmd"): live.add(n.get("name"))
        for k in ("children", "workers", "nodes"):
            for c in n.get(k, []) or []: collect_live(c)
# only walk the EXISTING (non-_swp) tree for liveness
for n in kids:
    if not n.get("_swp"): collect_live(n)

# 1) preferred: lift the applications_sup group out of the source and graft it whole.
app_groups = []
def find_groups(n):
    if isinstance(n, dict):
        if n.get("name") == "applications_sup":
            app_groups.append(n)
        for k in ("children", "workers", "nodes"):
            for c in n.get(k, []) or []: find_groups(c)
find_groups(src)

found = []
if app_groups:
    for g in app_groups:
        g = dict(g); g["_swp"] = name
        found.append(g)
    n_procs = sum(len(g.get("children", g.get("workers", g.get("nodes", []))) or []) for g in app_groups)
else:
    # 2) fallback: graft app worker leaves not already supervised live.
    procset = set(procs)
    def walk(n):
        if isinstance(n, dict):
            if n.get("name") in procset and n.get("start_cmd") and n.get("name") not in live:
                found.append({**n, "_swp": name})
            for k in ("children", "workers", "nodes"):
                for c in n.get(k, []) or []: walk(c)
    walk(src)
    n_procs = len(found)

kids[:] = [n for n in kids if n.get("_swp") != name]   # drop prior install of this SWP
kids.extend(found)
tmp = exec_path + ".tmp"
json.dump(tree, open(tmp, "w"), indent=2)
os.replace(tmp, exec_path)
print(f"theia-swp: merged SWP '{name}' ({n_procs} app proc(s)) into {exec_path}")
PY
}

# Read {app, machine} from machines.json: the SWP name + THIS board's slice.
# PER-MACHINE: prefer $THEIA_MACHINE (the board's own identity, exported by the
# supervisor unit) if the SWP ships a slice for it — so a multi-machine SWP
# (on=[central,compute]) applies the CORRECT slice on each board, not on[0]
# everywhere. Fall back to on[0] for a single-machine SWP or an unset $THEIA_MACHINE.
_swp_name() { python3 -c 'import json,sys;print(json.load(open(sys.argv[1])).get("app","unknown"))' "$1"; }
_swp_machine() {
    python3 -c 'import json,sys,os
d=json.load(open(sys.argv[1]))
on=d.get("on") or d.get("roles") or []
me=os.environ.get("THEIA_MACHINE","")
print(me if me and me in on else (on[0] if on else ""))' "$1"; }
_swp_procs() {
    # the SWP's process names = the application.json processes for the SWP app,
    # OR every bin/<fc> we shipped (fallback). Echo space-separated.
    mj="$1"; appj="$2"
    if [ -n "$appj" ] && [ -f "$appj" ]; then
        python3 - "$appj" <<'PY'
import json,sys
d=json.load(open(sys.argv[1]))
ps=[]
for a in d.get("applications",[]):
    ps += a.get("processes",[])
print(" ".join(ps))
PY
    fi
}

# Run a MAJOR SWP's CONFIG migration BEFORE the overlay/merge. A major (.art
# interface) bump ships migration/{migration.json, libper_migrate_*.so,
# transforms} in its payload (theia release-swp --migrate). The migration runs
# in C++ via /opt/theia/bin/theia-migrate — Snapshot(pre-<artifact>) +
# MigrateBulk per step over TIPC to per; NO python/probe/artheia on the rig
# (the probe is a dev tool, it ships to no board). It reads migration.json from
# the payload; the plugin .so is dlopen'd BY PER. This runs against the
# STILL-OLD release ($CURRENT), so per still holds the pre-upgrade config. A
# non-zero exit ABORTS the install (Mender rolls back) — a broken migration
# must not leave a half-migrated box. No migration/ dir → free-swap no-op.
#
# NB: hand-authored v<F>-to-v<T>.py migrations are NOT run (no python on the
# rig). A future non-config migration step would grow its own C++ tool the same
# way; config migration is theia-migrate's job.
_run_migration() {
    work="$1"
    [ -f "$work/migration/migration.json" ] || {
        echo "theia-swp: no config migration (free-swap SWP)"; return 0; }
    tm="$THEIA_ROOT/bin/theia-migrate"
    [ -x "$tm" ] || { echo "theia-swp: $tm missing (runtime too old for config migration)" >&2; return 1; }
    echo "theia-swp: running config migration (theia-migrate forward)"
    if "$tm" forward "$work/migration"; then
        echo "theia-swp: config migration OK"
        return 0
    else
        echo "theia-swp: config migration FAILED — aborting install" >&2
        return 1
    fi
}

# The RUNTIME the installed theia-runtime deb reports (M.m.p), or "" if the deb
# isn't installed (runtime not provisioned). The runtime is a deb (colony
# orchestrate → dpkg install), NOT the /opt/theia/current SWP overlay dir — so
# this is the authoritative "is the base present + which version" on-device.
_installed_runtime() {
    dpkg-query -W -f='${Version}' theia-runtime 2>/dev/null || true
}

# Does the installed runtime satisfy the SWP's requires_runtime? EQUALITY UP TO
# PATCH: major.minor must match exactly, patch is tolerated (0.2.7 satisfies a
# 0.2.2 pin; 0.3.0 does NOT). An empty pin = unpinned SWP → always satisfied.
# Strips a trailing abi suffix from the pin (0.2.2-amd64 → 0.2.2) and any deb
# epoch/revision from the installed version.
_runtime_satisfies() {
    pin="$1"; got="$2"
    [ -n "$pin" ] || return 0                 # unpinned → satisfied
    [ -n "$got" ] || return 1                 # no runtime installed → not satisfied
    # normalize: drop -<abi> from pin, drop epoch (N:) and -<rev> from the deb ver.
    pin_mm="$(echo "$pin" | sed 's/-[a-z0-9._-]*$//' | cut -d. -f1,2)"
    got_mm="$(echo "$got" | sed 's/^[0-9]*://; s/-.*$//' | cut -d. -f1,2)"
    [ "$pin_mm" = "$got_mm" ]
}

# Gate the SWP install on the runtime dependency (the deploy-sequencing fix). The
# GS fans runtime→colony and app→Mender in PARALLEL, so the SWP can reach the
# device before its runtime deb is installed. Rather than overlay onto a missing
# runtime, WAIT: re-check every 10s (the runtime deb is small + lands fast) up to
# a long timeout — cancellation is the escape hatch (a cancelled Mender
# deployment SIGTERMs this script; the short sleep makes the loop responsive).
# Returns 0 once satisfied; non-zero on timeout (Mender fails → retries later).
_require_runtime() {
    pin="$1"
    got="$(_installed_runtime)"
    if _runtime_satisfies "$pin" "$got"; then
        echo "theia-swp: runtime dependency satisfied (requires '$pin', installed '$got')"
        return 0
    fi
    # T = long ceiling (colony may install runtime serially across many boards;
    # this board just waits its turn). 10s poll → ~1h ceiling by default; override
    # with THEIA_SWP_RUNTIME_WAIT_S. Cancel via the GS to abort sooner.
    T="${THEIA_SWP_RUNTIME_WAIT_S:-3600}"
    echo "theia-swp: runtime not ready (requires '$pin', installed '${got:-none}') — SWP PENDING, re-checking every 10s (up to ${T}s; cancel in the GS to abort)"
    waited=0
    while [ "$waited" -lt "$T" ]; do
        sleep 10
        waited=$((waited + 10))
        got="$(_installed_runtime)"
        if _runtime_satisfies "$pin" "$got"; then
            echo "theia-swp: runtime now satisfied (installed '$got') after ${waited}s — proceeding"
            return 0
        fi
    done
    echo "theia-swp: runtime dependency '$pin' not satisfied within ${T}s (installed '${got:-none}') — failing install; redeploy once the runtime is up" >&2
    return 1
}

# Make the running supervisor adopt the merged tree. The supervisor reads
# executor.json ONCE at startup and runs a static tree (no SIGHUP/inotify reload),
# so "reload" = RESTART it: it re-reads the now-merged executor.json and spawns the
# SWP's app processes alongside the services. Order of preference:
#   1. tdb reload          — if a future supervisor grows a dynamic-reload control.
#   2. systemctl restart   — a systemd rig (the unit re-execs the supervisor).
#   3. signal + relaunch    — a container/no-systemd rig: TERM the supervisor (it
#      reaps its children) then relaunch it detached the same way provision does.
# A restart is brief (services re-fork) but is the ONLY mechanism a static-tree
# supervisor has to adopt new children. Idempotent: a re-install just restarts again.
_reload_supervisor() {
    if [ -x "$THEIA_ROOT/bin/tdb" ] && "$THEIA_ROOT/bin/tdb" reload 2>/dev/null; then
        echo "theia-swp: supervisor reloaded (tdb)"
        return 0
    fi
    if command -v systemctl >/dev/null 2>&1 && systemctl cat theia-supervisor >/dev/null 2>&1; then
        systemctl restart theia-supervisor 2>/dev/null \
            && { echo "theia-swp: supervisor restarted (systemd) — adopting merged tree"; return 0; }
    fi
    # container / no-systemd: kill the supervisor (skip self/ssh), relaunch detached.
    # CRUCIAL: relaunch via the theia-run LAUNCHER, not the bare supervisor binary —
    # the supervisor is STRICT and refuses to start without THEIA_ROOT_DIR +
    # THEIA_SUPERVISOR_MANIFEST + LD_LIBRARY_PATH, which theia-run is the one place
    # that exports (the same script orchestrate/systemd use). A bare `setsid
    # supervisor` dies with "THEIA_ROOT_DIR is not set".
    launcher="$THEIA_ROOT/bin/theia-run"
    me=$$
    for pid in $(pgrep -x supervisor 2>/dev/null); do
        [ "$pid" = "$me" ] && continue
        kill -TERM "$pid" 2>/dev/null || true
    done
    # wait for it to exit + reap children (up to ~8s)
    i=0; while [ $i -lt 16 ] && pgrep -x supervisor >/dev/null 2>&1; do sleep 0.5; i=$((i+1)); done
    if [ -x "$launcher" ]; then
        ( THEIA_ROOT_DIR="$THEIA_ROOT" setsid "$launcher" >/var/log/theia-supervisor.log 2>&1 < /dev/null & )
        sleep 3
        pgrep -x supervisor >/dev/null 2>&1 \
            && echo "theia-swp: supervisor relaunched via theia-run (no systemd) — adopting merged tree" \
            || echo "theia-swp: supervisor relaunch did not come up — check /var/log/theia-supervisor.log" >&2
    elif [ -x "$THEIA_ROOT/bin/supervisor" ]; then
        # no launcher script (older release) — export the strict env ourselves.
        ( cd "$THEIA_ROOT" && THEIA_ROOT_DIR="$THEIA_ROOT" \
            THEIA_SUPERVISOR_MANIFEST="$THEIA_ROOT/config/executor.json" \
            LD_LIBRARY_PATH="$THEIA_ROOT/current/lib:${LD_LIBRARY_PATH:-}" \
            setsid "$THEIA_ROOT/bin/supervisor" >/var/log/theia-supervisor.log 2>&1 < /dev/null & )
        sleep 3
        pgrep -x supervisor >/dev/null 2>&1 \
            && echo "theia-swp: supervisor relaunched (no systemd, no launcher) — adopting merged tree" \
            || echo "theia-swp: supervisor relaunch did not come up — check /var/log/theia-supervisor.log" >&2
    else
        echo "theia-swp: no launcher/supervisor to relaunch (runtime not provisioned?) — adopts on next start" >&2
    fi
}

case "$STATE" in
  Download)
    : ;;   # let Mender auto-save the payload to files/

  ArtifactInstall)
    art="$(_artifact_name)"
    [ "$art" != "unknown" ] || { echo "theia-swp: no version.txt" >&2; exit 1; }

    # unpack the bundle tar to a temp dir
    tarball="$(ls "$FILES"/files/*.tar.* 2>/dev/null | head -1 || true)"
    [ -n "$tarball" ] || tarball="$(ls "$FILES"/*.tar.* 2>/dev/null | head -1 || true)"
    [ -n "$tarball" ] || { echo "theia-swp: no SWP tarball in payload" >&2; exit 1; }
    work="$(mktemp -d)"
    case "$tarball" in
      *.zst) zstd -dc "$tarball" | tar -x -C "$work" ;;
      *.gz)  tar -xzf "$tarball" -C "$work" ;;
      *)     tar -xf "$tarball"  -C "$work" ;;
    esac

    # RUNTIME PRECONDITION (deploy sequencing): the SWP overlays app FCs onto the
    # runtime base, which colony installs (theia-runtime deb) in PARALLEL with
    # this Mender deploy. Gate on it — WAIT until the installed runtime satisfies
    # the SWP's requires_runtime (major.minor), rather than overlaying onto a
    # missing/wrong base. requires_runtime.txt is in the payload; empty = unpinned.
    req_rt="$(_payload requires_runtime.txt)"
    pin=""; [ -n "$req_rt" ] && pin="$(tr -d '[:space:]' < "$req_rt")"
    _require_runtime "$pin" || { rm -rf "$work"; exit 1; }

    mj="$work/manifest/machines.json"
    [ -f "$mj" ] || { echo "theia-swp: no manifest/machines.json in payload" >&2; exit 1; }
    swp="$(_swp_name "$mj")"
    machine="$(_swp_machine "$mj")"
    appj="$work/manifest/$machine/application.json"
    srcexec="$work/manifest/$machine/executor.json"
    procs="$(_swp_procs "$mj" "$appj")"

    # MAJOR migration (if any) runs FIRST — against the still-old release, before we
    # overlay the new binaries or merge the executor. A failed migration aborts the
    # install so Mender rolls back (no half-migrated box). No-op for a PATCH SWP.
    _run_migration "$work" || { rm -rf "$work"; exit 1; }

    # The overlay target. The runtime precondition above guarantees the base deb
    # is installed, so $CURRENT/bin normally exists. A pinned SWP that got here
    # has its runtime; an UNPINNED (legacy) SWP may still land before a runtime —
    # create the dir so its binaries stage (they run once a runtime lands under
    # the same $CURRENT). A pinned SWP never hits this fallback.
    [ -d "$CURRENT/bin" ] || { mkdir -p "$CURRENT/bin"; echo "theia-swp: $CURRENT/bin created (unpinned SWP, runtime not yet provisioned)"; }

    # back up the prior install of THIS SWP (bin copies + the executor) for rollback
    rec="$SWP_STATE/$swp"
    mkdir -p "$rec/prev-bin"
    cp -f "$EXEC" "$rec/executor.prev.json" 2>/dev/null || true
    # overlay the SWP FC executables into the live release, saving any displaced file
    for b in "$work"/bin/*; do
        [ -f "$b" ] || continue
        bn="$(basename "$b")"
        if [ -f "$CURRENT/bin/$bn" ]; then cp -f "$CURRENT/bin/$bn" "$rec/prev-bin/$bn"; fi
        install -m 0755 "$b" "$CURRENT/bin/$bn"
        echo "theia-swp: overlaid $CURRENT/bin/$bn"
    done
    # overlay any support-asset subtrees (e.g. a gateway PSP plugin: psp/libpsp.so)
    for d in psp lib; do
        [ -d "$work/$d" ] || continue
        if [ -d "$CURRENT/$d" ]; then cp -a "$CURRENT/$d" "$rec/prev-$d"; fi
        mkdir -p "$CURRENT/$d"
        cp -a "$work/$d/." "$CURRENT/$d/"
        echo "theia-swp: overlaid $CURRENT/$d/ (SWP asset dir)"
    done
    # merge the SWP's executor subtree + record the install (ship the manifest so a
    # later runtime install / debug can read what landed).
    mkdir -p "$rec/manifest"
    cp -af "$work/manifest/." "$rec/manifest/" 2>/dev/null || true
    # keep the migration part (driver + migration.json + plugins) so
    # ArtifactRollback can restore the pre-migration config snapshot.
    if [ -d "$work/migration" ]; then
        rm -rf "$rec/migration"
        cp -a "$work/migration" "$rec/migration"
    fi
    echo "$art" > "$rec/.artifact"
    if [ -f "$srcexec" ] && [ -n "$procs" ]; then
        _merge_executor "$swp" "$srcexec" "$procs"
    else
        echo "theia-swp: no executor subtree to merge (procs='$procs')" >&2
    fi
    rm -rf "$work"
    echo "theia-swp: installed SWP '$swp' ($art) → procs: $procs"
    ;;

  ArtifactCommit)
    # the overlay + executor merge happened in ArtifactInstall; now make the running
    # supervisor adopt the merged tree (restart — the static-tree supervisor has no
    # hot-reload) so the SWP's app processes actually spawn.
    _reload_supervisor
    echo "theia-swp: committed" ;;

  ArtifactRollback)
    last="$(ls -t "$SWP_STATE"/*/.artifact 2>/dev/null | head -1 || true)"
    if [ -n "$last" ]; then
        rec="$(dirname "$last")"; swp="$(basename "$rec")"
        [ -f "$rec/executor.prev.json" ] && cp -f "$rec/executor.prev.json" "$EXEC"
        for b in "$rec"/prev-bin/*; do
            [ -f "$b" ] && install -m 0755 "$b" "$CURRENT/bin/$(basename "$b")"
        done
        for d in psp lib; do
            [ -d "$rec/prev-$d" ] && { rm -rf "$CURRENT/$d"; cp -a "$rec/prev-$d" "$CURRENT/$d"; }
        done
        # Config rollback: theia-migrate restores the pre-update per snapshot
        # (RestoreSnapshot "pre-<artifact>"). LOUD on failure but does NOT block
        # the SW restore — a rolled-back box with migrated config needs operator
        # attention, not a wedged Mender state; the deployment log carries it.
        if [ -f "$rec/migration/migration.json" ] && [ -x "$THEIA_ROOT/bin/theia-migrate" ]; then
            if "$THEIA_ROOT/bin/theia-migrate" rollback "$rec/migration"; then
                echo "theia-swp: config snapshot restored (pre-update per state)"
            else
                echo "theia-swp: CONFIG ROLLBACK FAILED — SW restored but the per config may still be at the NEW shape; restore snapshot 'pre-$(cat "$rec/.artifact" 2>/dev/null)' manually (tdb / PerManager.RestoreSnapshot)" >&2
            fi
        fi
        echo "theia-swp: ROLLBACK SWP '$swp' (executor + binaries + assets restored)"
        _reload_supervisor
    else
        echo "theia-swp: nothing to roll back" >&2
    fi
    ;;

  ArtifactCommit_Leave|ArtifactInstall_Leave)
    _reload_supervisor ;;

  SupportsRollback)   echo "Yes" ;;
  NeedsArtifactReboot) echo "No" ;;
  *)                  exit 0 ;;
esac
