#!/bin/sh
# Mender STATE SCRIPT — runs on the device AFTER the theia-release module's
# ArtifactInstall state (the bits are now staged at /opt/theia/releases/<ver>
# and `current` has been re-aimed). This is the Mender → UCM hand-off.
#
# In production the theia-release module ONLY lands the release dir + flips the
# symlink (idempotent, fast, no service knowledge). The AUTOSAR lifecycle —
# stop/restart the affected FCs, PHM-health verify, ACTIVE-or-ROLLBACK — belongs
# to the on-device UCM agent (services/ucm). This script signals UCM to run it
# via UcmDaemon.RequestUpdate over TIPC. Mender owns "the release arrived + is on
# disk"; UCM owns "make theia adopt it safely". If this script exits non-zero
# Mender treats the install as failed → ArtifactRollback restores the previous
# symlink.
#
# The hand-off is NATIVE: `theia-migrate adopt` (the C++ tool that ships in the
# theia-runtime deb) makes the SAME RequestUpdate call the retired python
# ucm-adopt.py made, but over the runtime's own RemoteRef — NO python, NO
# artheia probe on the rig (the probe is a dev tool; it ships to no board). For a
# standalone (no UCM running) install it is a no-op success.
set -eu

THEIA_ROOT="${THEIA_ROOT:-/opt/theia}"
VER="$(readlink "$THEIA_ROOT/current" 2>/dev/null | sed 's#releases/##')"
[ -n "$VER" ] || { echo "ucm-request: no current release" >&2; exit 1; }

adopt="$THEIA_ROOT/bin/theia-migrate"
if [ ! -x "$adopt" ]; then
    # Runtime too old to carry the native adopter, or a bare dev box: the symlink
    # switch IS the install; the supervisor picks up `current` on restart.
    echo "ucm-request: no $adopt; symlink-only install of $VER (ok)"
    exit 0
fi

echo "ucm-request: signalling UcmDaemon.RequestUpdate to ADOPT $VER (sw/full)"
# `theia-migrate adopt` exits 0 if UCM accepts OR isn't reachable here (the
# symlink switch IS the install then), and non-zero ONLY on an explicit UCM
# REJECT → Mender's ArtifactRollback restores `previous`.
THEIA_ROOT="$THEIA_ROOT" "$adopt" adopt "$VER" full
