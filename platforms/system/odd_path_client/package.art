// ---- Licht_hinten_01 -----------------------------------------------------------------
// used:    LH_Blinker_HL_akt, LH_Blinker_HR_akt, LH_Bremslicht_H_aktiv
interface senderReceiver Licht_hinten_01_Iface {
    data Licht_hinten_01 pdu
}

// ---- RCTA_01 -----------------------------------------------------------------
// planned: RCTA_Kritikalitaetslevel_links, RCTA_Kritikalitaetslevel_rechts, RCTA_Notbremsung_Anforderung, RCTA_Status
interface senderReceiver RCTA_01_Iface {
    data RCTA_01 pdu
}

