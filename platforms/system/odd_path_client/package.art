// Odd-path-monitor vendor system fragment.
//
// Declares per-PDU senderReceiver interfaces over the FlexRay signals
// the odd-path-monitor app consumes. The message shapes themselves are
// imported from the AUTOSAR PSP — we don't redeclare them here. Each
// interface lists, in a // comment, the signals the app actually reads
// (used/planned per docs/signals.md in the upstream repo).
//
// Categories:
//   - Ego dynamics:  EML_01, LWI_01, ESP_05, Licht_hinten_01
//   - ADAS state:    GRA_ACC_01, AEB_01, LDW_02, RCTA_01
//   - Longitudinal:  ACC_06, ACC_07, ACC_10, KAS_01, FAS_VK_01
//   - Situational:   Getriebe_11, EPB_01, ESP_32
//   - Per-object:    BV2_ObjektHeader, BV2_Objekt_01..10

package vendor.odd_path_client.system

// PDU message defs come from the PSP's FIBEX import. textX cross-file
// references are single-file, so the import is documentation; the
// interfaces below use the bare type name and rely on a local
// forward-decl block at the bottom to keep parse happy.
import autosar.mlbevo_gen2_cmp_psp.system.mlbevo_gen2.*

// ---- ACC_06 -----------------------------------------------------------------
// planned: ACC_Sollbeschleunigung_02, ACC_Status_ACC, ACC_neg_Sollbeschl_Grad_02, ACC_pos_Sollbeschl_Grad_02
interface senderReceiver ACC_06_Iface {
    data ACC_06 pdu
}

// ---- ACC_07 -----------------------------------------------------------------
// planned: STA_Verzoeg_Anf, STA_Verzoeg_Anf_Freigabe
interface senderReceiver ACC_07_Iface {
    data ACC_07 pdu
}

// ---- ACC_10 -----------------------------------------------------------------
// planned: ANB_Teilbremsung_Freigabe, ANB_Zielbrems_Teilbrems_Verz_Anf, ANB_Zielbremsung_Freigabe, AWV1_Anf_Prefill
interface senderReceiver ACC_10_Iface {
    data ACC_10 pdu
}

// ---- AEB_01 -----------------------------------------------------------------
// planned: AEB_Anf_Prefill, AEB_Charisma_Status, AEB_Freigabe, AEB_Verz_Anf, AEB_Warnung
interface senderReceiver AEB_01_Iface {
    data AEB_01 pdu
}

// ---- EML_01 -----------------------------------------------------------------
// used:    EML_BeschlX, EML_GeschwX
// planned: EML_GierRate
interface senderReceiver EML_01_Iface {
    data EML_01 pdu
}

// ---- EPB_01 -----------------------------------------------------------------
// planned: EPB_Schalterposition
interface senderReceiver EPB_01_Iface {
    data EPB_01 pdu
}

// ---- ESP_05 -----------------------------------------------------------------
// planned: ESP_Bremsdruck, ESP_Fahrer_bremst
interface senderReceiver ESP_05_Iface {
    data ESP_05 pdu
}

// ---- ESP_32 -----------------------------------------------------------------
// planned: ESP_Aggregataktivitaet, ESP_Stillstandsflag
interface senderReceiver ESP_32_Iface {
    data ESP_32 pdu
}

// ---- FAS_VK_01 -----------------------------------------------------------------
// planned: FAS_VK_Status, FAS_VK_Verz_Anf, FAS_VK_Verz_Anf_ASIL
interface senderReceiver FAS_VK_01_Iface {
    data FAS_VK_01 pdu
}

// ---- GRA_ACC_01 -----------------------------------------------------------------
// planned: GRA_Hauptschalter, GRA_Limiter
interface senderReceiver GRA_ACC_01_Iface {
    data GRA_ACC_01 pdu
}

// ---- Getriebe_11 -----------------------------------------------------------------
// planned: GE_Fahrstufe
interface senderReceiver Getriebe_11_Iface {
    data Getriebe_11 pdu
}

// ---- KAS_01 -----------------------------------------------------------------
// planned: KAS_Kritikalitaetslevel, KAS_Status, KAS_Verz_Anf
interface senderReceiver KAS_01_Iface {
    data KAS_01 pdu
}

// ---- LDW_02 -----------------------------------------------------------------
// planned: LDW_DLC, LDW_Status_LED_gelb, LDW_TLC, LKS_LED_an
interface senderReceiver LDW_02_Iface {
    data LDW_02 pdu
}

// ---- LWI_01 -----------------------------------------------------------------
// planned: LWI_Lenkradwinkel
interface senderReceiver LWI_01_Iface {
    data LWI_01 pdu
