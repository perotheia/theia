package system.services.log


// The LOG/TRACE FC: the syslog sink (LogDaemon) plus the trace hub, which is
// two nodes sharing a process-global TraceHub — TraceStreamPump (runnable, raw
// record stream + ring + fan-out) and TraceCtl (atomic, Subscribe/Configure
// control). All three run in the one log process.
composition Log {
    prototype LogDaemon       log_daemon
    prototype TraceStreamPump trace_pump
    prototype TraceCtl        trace_ctl
}
