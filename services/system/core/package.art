// Core (CORE) — Adaptive Platform Functional Cluster.
//
// NOT A DAEMON. `ara::core` is a foundational header-only library;
// there is no Core daemon. See README.md.
//
// The atomic node is kept only so the TIPC type stays reserved and
// the package.art is parseable (artheia requires a node per FC).

package system.services.core

node atomic CoreDaemon {
    tipc type=0x80010001 instance=0
}
