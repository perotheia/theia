package system.services.osi


// The OS-Interface FC: OsiCtl — cgroup v2 resource partitioning + per-FC
// accounting. (The V2V relative-topology plane that once lived here moved OUT
// to standalone package repos under the perotheia-packages org; a user
// workspace imports + composes them. osi no longer owns any of it.)
composition Osi {
    prototype OsiCtl     osi_ctl
}
