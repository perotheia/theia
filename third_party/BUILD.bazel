# third_party/BUILD.bazel — exposes vendored deps to the Bazel graph.
#
# The dirs under third_party/ are pulled by `repo sync` from public
# sources (github remote in .repo/manifests/default.xml). Their own
# BUILD systems are CMake/Make/etc., NOT Bazel — we don't drop
# BUILD.bazel files inside them because that would pollute the
# foreign repos' git status.
#
# Instead we expose specific artifacts via filegroup labels here.

load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")
load("@rpi4_sysroot//:path.bzl", "RPI4_SYSROOT")
load("@orin_sysroot//:path.bzl", "ORIN_SYSROOT")
load(":patch_tree.bzl", "patched_source_tree")

package(default_visibility = ["//visibility:public"])

# Staged host-x86 codegen toolset matching the rpi4 sysroot's protobuf (bookworm
# 3.21.12 / grpc 1.51). RPI4_SYSROOT = <ws>/third_party/sysroot/rpi4, so this is
# <ws>/third_party/codegen-bookworm-x86 (gitignored host data; see
# services/com/BUILD.bazel for the same prefix used by the proto genrules).
_CG_DIR = RPI4_SYSROOT + "/../../codegen-bookworm-x86"

# Cross-compile cache entries for the etcd_cpp foreign_cc CMake build. On the
# host (x86) the empty default lets CMake find_package() the host -dev packages.
# Targeting aarch64 (//rules/config:rpi4) CMake must instead find Boost / cpprest
# / the grpc-chain (re2, c-ares) in the rpi4 SYSROOT, not on the host — so point
# CMAKE_FIND_ROOT_PATH + CMAKE_SYSROOT at it and force find_{library,include} to
# the sysroot ONLY (programs like cmake/make stay host = NEVER/BOTH).
_ETCD_CROSS_CACHE = select({
    # Jetson NATIVE build (focal aarch64, --define theia_target=jetson). The build
    # host IS the target ABI, so etcd find_package()s the host's Boost/grpc/
    # protobuf directly — NO sysroot, exactly like the x86 host branch. This
    # config_setting (cpu + define) is strictly more specialized than is_arm64
    # (cpu only), so bazel picks it over the rpi4 sysroot branch on the Jetson.
    "//rules/config:target_jetson": {},
    # Orin CROSS (jammy sysroot): same shape as rpi4 below; grpc/protobuf come
    # from the sysroot's /usr/local STATIC closure (setup_orin.sh built it) —
    # find_package resolves their cmake configs there. Codegen: the SAME staged
    # x86 bookworm toolset (protoc 3.21 / plugin 1.51 — versions match the
    # closure).
    "//rules/config:arm64_cross_orin": {
        "CMAKE_SYSROOT": ORIN_SYSROOT,
        "CMAKE_FIND_ROOT_PATH": ORIN_SYSROOT,
        "CMAKE_FIND_ROOT_PATH_MODE_PROGRAM": "NEVER",
        "CMAKE_FIND_ROOT_PATH_MODE_LIBRARY": "ONLY",
        "CMAKE_FIND_ROOT_PATH_MODE_INCLUDE": "ONLY",
        "CMAKE_FIND_ROOT_PATH_MODE_PACKAGE": "ONLY",
        "PKG_CONFIG_EXECUTABLE": "/usr/bin/pkg-config",
        "Protobuf_PROTOC_EXECUTABLE": _CG_DIR + "/bin/protoc",
        "_PROTOBUF_PROTOC": _CG_DIR + "/bin/protoc",
        # The orin closure is built with gRPC_BUILD_CODEGEN=OFF → its cmake
        # config exports NO gRPC::grpc_cpp_plugin target; the (Theia-patched)
        # etcd CMakeLists honors this cache override instead of querying it.
        "GRPC_CPP_PLUGIN": _CG_DIR + "/bin/grpc_cpp_plugin",
        "_GRPC_CPP_PLUGIN_EXECUTABLE": _CG_DIR + "/bin/grpc_cpp_plugin",
    },
    "//rules/config:arm64_cross": {
        "CMAKE_SYSROOT": RPI4_SYSROOT,
        "CMAKE_FIND_ROOT_PATH": RPI4_SYSROOT,
        "CMAKE_FIND_ROOT_PATH_MODE_PROGRAM": "NEVER",
        "CMAKE_FIND_ROOT_PATH_MODE_LIBRARY": "ONLY",
        "CMAKE_FIND_ROOT_PATH_MODE_INCLUDE": "ONLY",
        "CMAKE_FIND_ROOT_PATH_MODE_PACKAGE": "ONLY",
        # grpc's cmake config re-find_package(re2 / c-ares) via pkg-config. Point
        # CMake at the HOST pkg-config binary (a program, so excluded from the
        # sysroot-only find above); the env below aims it at the sysroot's .pc's.
        "PKG_CONFIG_EXECUTABLE": "/usr/bin/pkg-config",
        # CODEGEN tools must be HOST-arch (the build runs on x86) AND match the
        # sysroot's protobuf VERSION (bookworm 3.21.12 / grpc 1.51) — the sysroot's
        # own protoc/grpc_cpp_plugin are arm64 (can't exec) and the dev host's are
        # an older protobuf. Point at the staged host-x86 bookworm toolset (its
        # runtime .so's are on LD_LIBRARY_PATH via _ETCD_CROSS_ENV below). etcd's
        # CMakeLists reads protobuf::protoc / gRPC::grpc_cpp_plugin IMPORTED-target
        # LOCATIONs from the sysroot configs, so override them explicitly.
        "Protobuf_PROTOC_EXECUTABLE": _CG_DIR + "/bin/protoc",
        "_PROTOBUF_PROTOC": _CG_DIR + "/bin/protoc",
        "_GRPC_CPP_PLUGIN_EXECUTABLE": _CG_DIR + "/bin/grpc_cpp_plugin",
    },
    "//conditions:default": {},
})

# pkg-config env for the aarch64 build: search the sysroot's .pc files and
# rewrite their -L/-I prefixes through the sysroot (PKG_CONFIG_SYSROOT_DIR), so
# re2/c-ares resolve to the arm64 libs, not the host's.
_ETCD_CROSS_ENV = select({
    # Jetson native: no sysroot pkg-config rewrite — find the host .pc's. (See
    # the matching target_jetson branch in _ETCD_CROSS_CACHE above.)
    "//rules/config:target_jetson": {"CCACHE_DISABLE": "1"},
    "//rules/config:arm64_cross_orin": {
        "CCACHE_DISABLE": "1",
        "PKG_CONFIG_PATH": ORIN_SYSROOT + "/usr/lib/aarch64-linux-gnu/pkgconfig:" +
                           ORIN_SYSROOT + "/usr/local/lib/pkgconfig",
        "PKG_CONFIG_SYSROOT_DIR": ORIN_SYSROOT,
        "LD_LIBRARY_PATH": _CG_DIR + "/lib",
    },
    "//rules/config:arm64_cross": {
        "CCACHE_DISABLE": "1",
        "PKG_CONFIG_PATH": RPI4_SYSROOT + "/usr/lib/aarch64-linux-gnu/pkgconfig",
        "PKG_CONFIG_SYSROOT_DIR": RPI4_SYSROOT,
        # The staged host-x86 protoc/grpc_cpp_plugin (3.21.12 / 1.51) need their
        # bookworm runtime .so's (libprotoc.so.32, libgrpc_plugin_support.so.1.51).
        "LD_LIBRARY_PATH": _CG_DIR + "/lib",
    },
    "//conditions:default": {"CCACHE_DISABLE": "1"},
})

# etcd-cpp-apiv3 — vendored at v0.2.14 as a git SUBMODULE (see .gitmodules).
# It is now built HERMETICALLY by Bazel via rules_foreign_cc's cmake() rule
# (no committed install/ tree, no prebuilt .so). The cmake() runs the vendored
# CMakeLists OUT-OF-SOURCE inside bazel-out/, producing a STATIC archive that
# links straight into services/per. Nothing under etcd-cpp-apiv3/{build,install}
# is committed or required for the Bazel build.
#
# A direct (out-of-Bazel) dev build still works the old way if you want one:
#   cmake -S third_party/etcd-cpp-apiv3 -B third_party/etcd-cpp-apiv3/build \
#         -DBUILD_ETCD_TESTS=OFF -DETCD_W_STRICT=OFF
#   cmake --build third_party/etcd-cpp-apiv3/build -j
# but Bazel no longer reads that tree.

# Legacy install-tree filegroup + alias, kept ONLY so out-of-gate consumers that
# still reference these labels (tools/supervisor-gui's cmake() data=) keep
# loading. The committed install/ tree is gone — these glob empty. supervisor-gui
# has its own etcd modernization pending; per (the gate) no longer uses these.
filegroup(
    name = "etcd-cpp-apiv3-install",
    srcs = glob(
        ["etcd-cpp-apiv3/install/**"],
        allow_empty = True,
    ),
)

alias(
    name = "etcd-cpp-apiv3",
    actual = ":etcd-cpp-apiv3-install",
)

# The submodule SOURCE tree fed to cmake(). cmake() copies lib_source into the
# sandbox before configuring, so we exclude the out-of-source build/install dirs
# (they must not exist) to keep the copy clean + reproducible. allow_empty keeps
# the package loadable on a fresh clone where the submodule isn't checked out
# yet (per's etcd_store is the only consumer and builds this on demand).
filegroup(
    name = "etcd-cpp-apiv3-raw-srcs",
    srcs = glob(
        ["etcd-cpp-apiv3/**"],
        exclude = [
            "etcd-cpp-apiv3/build/**",
            "etcd-cpp-apiv3/install/**",
        ],
        allow_empty = True,
    ),
)

# lib_source = the submodule tree with third_party/etcd-cpp-apiv3.patch applied
# (adds ETCD_BUILD_CORE_ONLY → drops Client.cpp + cpprestsdk). Emitted as ONE
# TreeArtifact so foreign_cc's detect_root finds a single source root; the
# submodule on disk stays PRISTINE.
patched_source_tree(
    name = "etcd-cpp-apiv3-srcs",
    srcs = ":etcd-cpp-apiv3-raw-srcs",
    strip_prefix = "etcd-cpp-apiv3/CMakeLists.txt",  # its dir = the copy root
    patch = "etcd-cpp-apiv3.patch",
    out_dir = "etcd-cpp-apiv3-patched",
)

# Hermetic from-scratch CMake build of the vendored etcd client, STATIC.
#
# out_static_libs: we emit ONLY libetcd-cpp-api-core.a. The vendored CMake builds
# the core objects (KeepAlive/Response/SyncClient/Value/Watcher + all generated
# protobuf/grpc .pb.cc) ONCE as an OBJECT library, then links them into BOTH
# `etcd-cpp-api-core` (SyncClient/Watcher) AND `etcd-cpp-api` (adds the async
# Client.cpp, which needs cpprest's pplx). services/per's etcd_store.cc uses ONLY
# etcd::SyncClient + etcd::Watcher, so -core is the complete, minimal archive —
# and it pulls in NO cpprest.
#
# *** gogoproto double-registration hazard ***
# Both -core.a and the non-core etcd-cpp-api.a carry the SAME compiled
# gogoproto/etcd protobuf descriptors (the gogoproto.goproto_enum_prefix
# extension, field 62001) because they share that one object library. Linking
# BOTH into a single binary registers that extension TWICE → a fatal libprotobuf
# "Multiple extension registrations" abort at static-init. We therefore build +
# list EXACTLY ONE archive (-core) and never the other. One archive = one
# registration.
cmake(
    name = "etcd_cpp",
    lib_source = ":etcd-cpp-apiv3-srcs",
    # lib_source is a TreeArtifact dir; detect_root resolves to its PARENT
    # (third_party), so point cmake at the tree itself (where CMakeLists.txt is).
    working_directory = "etcd-cpp-apiv3-patched",
    cache_entries = {
        # Static libs (.a), PIC so they slot into our PIC binaries; tests off so
        # we don't compile/run the etcd test suite; -Werror off so a newer host
        # compiler doesn't fail the vendored code on a new warning.
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_POSITION_INDEPENDENT_CODE": "ON",
        "BUILD_ETCD_TESTS": "OFF",
        "ETCD_W_STRICT": "OFF",
        # The client API is C++17 in our tree (matches services/per copts).
        "ETCD_CMAKE_CXX_STANDARD": "17",
        # Theia patch: build ONLY the synchronous -core library. Skips Client.cpp
        # (the async client) + its find_package(cpprestsdk), so the build needs NO
        # cpprestsdk in the sysroot at all. per links etcd::SyncClient/Watcher
        # only, so -core is complete. Also kills the gogoproto double-registration
        # hazard for free: only ONE archive is ever built.
        "ETCD_BUILD_CORE_ONLY": "ON",
    } | _ETCD_CROSS_CACHE,   # aarch64: redirect find_package to the rpi4 sysroot
    # Only -core exists now (ETCD_BUILD_CORE_ONLY skips the async etcd-cpp-api).
    targets = ["etcd-cpp-api-core"],
    out_static_libs = ["libetcd-cpp-api-core.a"],
    # The vendored CMakeLists auto-enables ccache if it finds it on PATH, but
    # ccache's temp dir (/run/user/.../ccache-tmp) is read-only in the Bazel
    # sandbox → "Failed to create temporary file ... Read-only file system".
    # Disable ccache for this hermetic build (Bazel already caches the action).
    # The aarch64 branch also adds PKG_CONFIG_PATH/_SYSROOT_DIR for the grpc-chain
    # find_package(re2 / c-ares).
    env = _ETCD_CROSS_ENV,
    # Headers install under include/ (out_include_dir defaults to "include").
    visibility = ["//visibility:public"],
)

# Pure-Bazel cc_library a normal cc_binary consumer (services/per's etcd_store)
# depends on. It re-exports the cmake() static archive + headers and supplies the
# TRANSITIVE system libs the static etcd.a does NOT carry (a static archive
# records no link deps of its own). These are all host-apt .so's: grpc++/grpc/gpr,
# the reflection-capable libprotobuf, OpenSSL, Boost system/thread/random, plus
# pthread/dl. With static linking there is NO runtime libetcd .so to find, so the
# old RPATH lines are gone.
cc_library(
    name = "etcd_cc",
    deps = [
        ":etcd_cpp",
    ],
    linkopts = [
        "-lgrpc++",
        "-lgrpc",
        "-lgpr",
        # bookworm's grpc 1.51 no longer DT_NEEDED-pulls abseil, so the etcd
        # .a's grpc-generated TUs leave absl::Mutex undefined. Pull it explicitly
        # (DT_NEEDED-pulls its own absl deps) — same fix as com_bridge_grpc.
        "-labsl_synchronization",
        "-lprotobuf",
        "-lssl",
        "-lcrypto",
        "-lboost_system",
        "-lboost_thread",
        "-lboost_random",
        "-lpthread",
        "-ldl",
    ],
    visibility = ["//visibility:public"],
)


# nlohmann/json — single-header JSON library vendored under
# third_party/nlohmann_json/nlohmann/json.hpp. Single canonical
# config format across the system (manifests + supervisor reads)
# since #380; the C++ side parses with this header-only lib (no
# yaml-cpp link step).
#
# Consumers:
#   - platform/supervisor (CMake build — picks up the header via
#     NLOHMANN_JSON_INCLUDE_DIR cache var)
#   - supervisor-gui (rules_foreign_cc cmake() build — needs the
#     filegroup mounted into the sandbox via `data=`)
filegroup(
    name = "nlohmann_json_hdrs",
    srcs = glob(["nlohmann_json/**/*.hpp"], allow_empty = False),
)

# Header-only cc_library, in case any pure-Bazel cc_binary picks
# this up directly (no current consumer, but cheap to expose).
cc_library(
    name = "nlohmann_json",
    hdrs = glob(["nlohmann_json/**/*.hpp"], allow_empty = False),
    includes = ["nlohmann_json"],
    visibility = ["//visibility:public"],
)


# Host-installed Google libprotobuf (libprotobuf-dev). Distinct from
# nanopb: this is the REFLECTION-capable C++ library, used by host
# tools (libtrace_decoder, supdbg) that need MessageToJsonString.
# Apps + on-target services keep using the much smaller nanopb stack.
#
# We link the system library directly rather than vendoring because:
# (a) every dev box already has libprotobuf-dev for protoc;
# (b) the reflection library is large (~6 MB stripped) and target
#     builds for Hercules/RPi4 don't want it.
#
# Verify availability with `pkg-config --modversion protobuf` and
# that /usr/include/google/protobuf/util/json_util.h exists.
cc_library(
    name = "system_protobuf",
    hdrs = [],
    linkopts = [
        "-lprotobuf",
    ],
    visibility = ["//visibility:public"],
)
