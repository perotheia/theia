# third_party/BUILD.bazel — exposes vendored deps to the Bazel graph.
#
# The dirs under third_party/ are pulled by `repo sync` from public
# sources (github remote in .repo/manifests/default.xml). Their own
# BUILD systems are CMake/Make/etc., NOT Bazel — we don't drop
# BUILD.bazel files inside them because that would pollute the
# foreign repos' git status.
#
# Instead we expose specific artifacts via filegroup labels here.

load("@rules_cc//cc:defs.bzl", "cc_import", "cc_library")

package(default_visibility = ["//visibility:public"])

# etcd-cpp-apiv3 — vendored at v0.2.14, built+installed by an
# out-of-Bazel cmake invocation into third_party/etcd-cpp-apiv3/install/.
# Consumers (supervisor-gui, platform/supervisor) feed this filegroup
# to rules_foreign_cc's cmake() rule via `data = [...]` so the install
# tree is materialized inside the sandbox.
#
# Bootstrap if missing:
#   repo sync etcd-cpp-apiv3/etcd-cpp-apiv3
#   cmake -S third_party/etcd-cpp-apiv3 \
#         -B third_party/etcd-cpp-apiv3/build \
#         -DCMAKE_INSTALL_PREFIX=third_party/etcd-cpp-apiv3/install \
#         -DBUILD_ETCD_TESTS=OFF -DETCD_W_STRICT=OFF
#   cmake --build third_party/etcd-cpp-apiv3/build -j
#   cmake --install third_party/etcd-cpp-apiv3/build
filegroup(
    name = "etcd-cpp-apiv3-install",
    srcs = glob(
        ["etcd-cpp-apiv3/install/**"],
        allow_empty = True,
    ),
)

# Just the one .so the per binary links at runtime, as a FILE (cc_import's
# :etcd_cpp_so doesn't expose it via DefaultInfo). dist_ipk bundles this into
# /opt/theia/lib/ so per resolves it under LD_LIBRARY_PATH on the target.
filegroup(
    name = "etcd_cpp_so_file",
    srcs = ["etcd-cpp-apiv3/install/lib/libetcd-cpp-api.so"],
    visibility = ["//visibility:public"],
)

# Alias under the dir name so consumers can write
# //third_party/etcd-cpp-apiv3:install and read intent at the
# call site.
alias(
    name = "etcd-cpp-apiv3",
    actual = ":etcd-cpp-apiv3-install",
)

# Pure-Bazel cc_library for a normal cc_library/cc_binary consumer (e.g.
# services/per's etcd_store) — exposes the etcd-cpp-apiv3 install headers +
# links the prebuilt shared lib. The .so's transitive deps (grpc++, libprotobuf,
# cpprest, ssl) are host system libs that resolve at load time. The RPATH below
# lets the per binary find libetcd-cpp-api*.so at run time from the source tree.
# Link ONLY libetcd-cpp-api.so. It is self-contained (the SyncClient/Watcher
# symbols + the etcd/gogoproto descriptors), and does NOT depend on
# libetcd-cpp-api-core.so at runtime. The -core .so embeds the SAME gogoproto
# extension descriptors (gogoproto.goproto_enum_prefix, field 62001); linking
# BOTH registers that extension TWICE → a fatal libprotobuf "Multiple extension
# registrations" abort at startup. One .so = one registration.
cc_import(
    name = "etcd_cpp_so",
    shared_library = "etcd-cpp-apiv3/install/lib/libetcd-cpp-api.so",
)

cc_library(
    name = "etcd_cc",
    # allow_empty: etcd-cpp-apiv3/install/ is a BUILD output (the submodule's
    # source has no install/ until it's compiled). On a fresh clone that dir is
    # absent — without allow_empty the glob aborts and the WHOLE third_party
    # package fails to load, cascading to unrelated targets (nlohmann_json, the
    # supervisor build). per's etcd_store is the only consumer; it builds this
    # after building etcd. allow_empty keeps the package loadable meanwhile.
    hdrs = glob(["etcd-cpp-apiv3/install/include/**/*.hpp"], allow_empty = True),
    includes = ["etcd-cpp-apiv3/install/include"],
    deps = [
        ":etcd_cpp_so",
    ],
    # Find the .so's at run time relative to the binary (bazel-bin) and from an
    # installed tree; the absolute source path is the dev-run fallback.
    linkopts = [
        "-Wl,-rpath,$$ORIGIN/../../../third_party/etcd-cpp-apiv3/install/lib",
        "-Wl,-rpath,/home/axadmin/repo/theia/third_party/etcd-cpp-apiv3/install/lib",
    ],
    visibility = ["//visibility:public"],
)


# nlohmann/json — single-header JSON library vendored under
# third_party/nlohmann_json/nlohmann/json.hpp. Single canonical
# config format across the system (manifests + supervisor reads)
# since #380; the C++ side parses with this header-only lib (no
# yaml-cpp link step).
#
# Consumers:
#   - platform/supervisor (CMake build — picks up the header via
#     NLOHMANN_JSON_INCLUDE_DIR cache var)
#   - supervisor-gui (rules_foreign_cc cmake() build — needs the
#     filegroup mounted into the sandbox via `data=`)
filegroup(
    name = "nlohmann_json_hdrs",
    srcs = glob(["nlohmann_json/**/*.hpp"], allow_empty = False),
)

# Header-only cc_library, in case any pure-Bazel cc_binary picks
# this up directly (no current consumer, but cheap to expose).
cc_library(
    name = "nlohmann_json",
    hdrs = glob(["nlohmann_json/**/*.hpp"], allow_empty = False),
    includes = ["nlohmann_json"],
    visibility = ["//visibility:public"],
)


# Host-installed Google libprotobuf (libprotobuf-dev). Distinct from
# nanopb: this is the REFLECTION-capable C++ library, used by host
# tools (libtrace_decoder, supdbg) that need MessageToJsonString.
# Apps + on-target services keep using the much smaller nanopb stack.
#
# We link the system library directly rather than vendoring because:
# (a) every dev box already has libprotobuf-dev for protoc;
# (b) the reflection library is large (~6 MB stripped) and target
#     builds for Hercules/RPi4 don't want it.
#
# Verify availability with `pkg-config --modversion protobuf` and
# that /usr/include/google/protobuf/util/json_util.h exists.
cc_library(
    name = "system_protobuf",
    hdrs = [],
    linkopts = [
        "-lprotobuf",
    ],
    visibility = ["//visibility:public"],
)
