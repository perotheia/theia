 add_library(etcd-cpp-api $<TARGET_OBJECTS:etcd-cpp-api-core-objects>
                          "${CMAKE_CURRENT_SOURCE_DIR}/Client.cpp")
 use_cxx(etcd-cpp-api)
@@ -51,14 +53,20 @@ target_link_libraries(etcd-cpp-api PUBLIC
                       ${GRPC_LIBRARIES}
 )
 include_generated_protobuf_files(etcd-cpp-api)
+endif()
 
+# Install: include etcd-cpp-api only when it was built (Theia patch).
+set(_etcd_install_targets etcd-cpp-api-core)
+if(NOT ETCD_BUILD_CORE_ONLY)
+    list(APPEND _etcd_install_targets etcd-cpp-api)
+endif()
 if("${CMAKE_VERSION}" VERSION_LESS "3.14")
-    install(TARGETS etcd-cpp-api-core etcd-cpp-api
+    install(TARGETS ${_etcd_install_targets}
             EXPORT etcd-targets
