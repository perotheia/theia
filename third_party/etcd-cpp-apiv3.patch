diff --git a/CMakeLists.txt b/CMakeLists.txt
index 8c568a5..a56f580 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -116,13 +116,22 @@ if(Protobuf_PROTOC_EXECUTABLE)
         endif()
     endif()
 endif()
-find_package(cpprestsdk QUIET)
-if(cpprestsdk_FOUND)
-    set(CPPREST_INCLUDE_DIR)
-    set(CPPREST_LIB cpprestsdk::cpprest)
-else()
-    find_library(CPPREST_LIB NAMES cpprest)
-    find_path(CPPREST_INCLUDE_DIR NAMES cpprest/http_client.h)
+# Theia patch: ETCD_BUILD_CORE_ONLY skips the asynchronous client (Client.cpp),
+# the SOLE consumer of cpprestsdk (pplx::task). services/per links only the
+# synchronous -core library (SyncClient + Watcher, pure gRPC), so cpprestsdk and
+# its dependency weight are unnecessary. OFF by default (upstream behaviour
+# preserved); Theia's foreign_cc cmake() passes it ON.
+option(ETCD_BUILD_CORE_ONLY
+       "Build only the synchronous -core library; skip Client.cpp + cpprestsdk" OFF)
+if(NOT ETCD_BUILD_CORE_ONLY)
+    find_package(cpprestsdk QUIET)
+    if(cpprestsdk_FOUND)
+        set(CPPREST_INCLUDE_DIR)
+        set(CPPREST_LIB cpprestsdk::cpprest)
+    else()
+        find_library(CPPREST_LIB NAMES cpprest)
+        find_path(CPPREST_INCLUDE_DIR NAMES cpprest/http_client.h)
+    endif()
 endif()
 
 find_package(gRPC QUIET)
